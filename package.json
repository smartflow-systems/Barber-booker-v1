{
  "name": "barber-booker-tempate-v1",
  "version": "0.1.0",
  "description": "Smartflow Store MVP API with Multi-Agent Orchestration",
  "main": "server.js",
  "private": true,
  "scripts": {
    "start": "npx tsx --env-file .env server/index.ts",
    "dev": "npx tsx --env-file .env server/index.ts",
    "orchestrator": "node server/orchestrator/index.js",
    "agent": "node scripts/sfs-agent-cli.js",
    "sync": "bash scripts/auto-sync.sh",
    "sync:watch": "node scripts/sync-chatgpt-claude.js watch",
    "build": "echo 'build complete' && exit 0",
    "test": "echo 'no tests configured' && exit 0",
    "migrate": "prisma migrate dev --name init",
    "studio": "prisma studio",
    "dev:5100": "PORT=5100 node server.js",
    "pull": "git pull --no-edit",
    "push": "git push",
    "auto-commit": "git add . && git commit -m 'chore: auto-commit [Auto-Sync]' || true",
    "sync-all": "npm run auto-commit && npm run sync"
  },
